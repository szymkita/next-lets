<script>
  // ---- Sticky header: cień/obramowanie po scrollu ----
  (function(){
    var h = document.querySelector('.site-header');
    if(!h) return;
    function upd(){ h.classList.toggle('scrolled', window.scrollY > 130); }
    upd();
    window.addEventListener('scroll', upd, {passive:true});
  })();

  // ---- Hero: makieta pulpitu skalowana do szerokości kontenera ----
  (function(){
    var frame = document.querySelector('.mockup-frame');
    var scale = document.querySelector('.mockup-scale');
    if(!frame || !scale) return;
    function fit(){
      var w = frame.clientWidth;
      var s = Math.min(1, w / 1180);
      scale.style.transform = 'scale(' + s + ')';
      frame.style.height = (400 * s) + 'px';
    }
    fit();
    window.addEventListener('resize', fit);
    window.addEventListener('load', fit);
  })();

  // ---- Rotator (S1b) — pionowe przewijanie fraz co 3s ----
  (function(){
    var col = document.getElementById('rotator-col');
    if(!col) return;
    var count = col.children.length;
    var i = 0;
    setInterval(function(){
      i = (i + 1) % count;
      var h = col.children[0].offsetHeight || 60;
      col.style.transform = 'translateY(-' + (i * h) + 'px)';
    }, 3000);
  })();

  // ---- Droga pod hero (S1b, wariant A) — reveal wykresu i osi czasu ----
  (function(){
    var sec = document.querySelector('.la-droga');
    if(!sec) return;
    if(!('IntersectionObserver' in window)){ sec.classList.add('in'); return; }
    var io = new IntersectionObserver(function(entries){
      entries.forEach(function(e){ if(e.isIntersecting){ sec.classList.add('in'); io.disconnect(); } });
    }, { threshold: 0.25 });
    io.observe(sec);
  })();

  // ---- FAQ (S9b) — akordeon ----
  (function(){
    var items = document.querySelectorAll('.faq-item');
    if(!items.length) return;
    items.forEach(function(item){
      var btn = item.querySelector('.faq-q');
      if(!btn) return;
      btn.addEventListener('click', function(){
        var willOpen = !item.classList.contains('open');
        items.forEach(function(other){
          other.classList.remove('open');
          var b = other.querySelector('.faq-q');
          if(b) b.setAttribute('aria-expanded', 'false');
        });
        if(willOpen){
          item.classList.add('open');
          btn.setAttribute('aria-expanded', 'true');
        }
      });
    });
  })();

  // ---- Zakładki oferty (S4) — Strategia / Aplikacje / AI / Opieka ----
  (function(){
    var tabs = document.querySelectorAll('.krok-tab');
    var layers = document.querySelectorAll('.krok-layer');
    function setKrok(k){
      tabs.forEach(function(t){
        var on = t.dataset.krok === k;
        t.style.background = on ? '#ffffff' : 'transparent';
        t.style.boxShadow = on ? '0 12px 28px -16px rgba(12,28,20,0.3)' : 'none';
        var num = t.querySelector('.krok-num');
        if(num) num.style.color = on ? '#0a7a52' : '#808b83';
      });
      layers.forEach(function(l){
        var on = l.dataset.layer === k;
        l.style.opacity = on ? '1' : '0';
        l.style.transform = on ? 'translateY(0)' : 'translateY(14px)';
        l.style.pointerEvents = on ? 'auto' : 'none';
        l.classList.toggle('active', on);
      });
    }
    tabs.forEach(function(t){ t.addEventListener('click', function(){ setKrok(t.dataset.krok); }); });
    setKrok('strat');
  })();

  // ---- Rachunek (S2) — licznik od 0 do wartości docelowej gdy widoczny ----
  (function(){
    var el = document.getElementById('la8-rachunek');
    if(!el) return;
    var vals = el.querySelectorAll('.rcpt-val');
    var totalEl = document.getElementById('rcpt-total');
    var done = false;
    function animate(){
      if(done) return; done = true;
      var t0 = performance.now();
      function step(t){
        var p = Math.min(1, (t - t0) / 1500);
        var rp = 1 - Math.pow(1 - p, 3);
        vals.forEach(function(v){ v.textContent = Math.round(v.dataset.h * rp) + ' h'; });
        if(totalEl) totalEl.textContent = Math.round(totalEl.dataset.total * rp);
        if(p < 1) requestAnimationFrame(step);
      }
      requestAnimationFrame(step);
    }
    if('IntersectionObserver' in window){
      var io = new IntersectionObserver(function(entries){
        entries.forEach(function(e){ if(e.isIntersecting){ animate(); io.disconnect(); } });
      }, { threshold: 0.2 });
      io.observe(el);
    } else { animate(); }
  })();

  // ---- Pulpit (hero) — sporadyczny wzrost licznika zadań ----
  (function(){
    var numEl = document.getElementById('tasksNum');
    var labelEl = document.getElementById('tasksLabel');
    if(!numEl) return;
    var n = 42;
    function word(x){
      var m10 = x % 10, m100 = x % 100;
      return (m10 >= 2 && m10 <= 4 && !(m100 >= 12 && m100 <= 14)) ? 'zadania' : 'zadań';
    }
    setInterval(function(){
      if(Math.random() < 0.45){
        n += 1;
        numEl.textContent = n;
        if(labelEl) labelEl.textContent = n + ' ' + word(n) + ' zrobione dziś';
      }
    }, 5200);
  })();

  // ---- Nav CTA — rotujący typing (Bezpłatna diagnoza / Wyceń projekt / …) ----
  (function(){
    var el = document.querySelector('[data-cta-rotate]');
    if(!el) return;
    // UWAGA: szerokość przycisku trzyma ukryty .nav-cta-sizer w HTML —
    // musi zawierać NAJDŁUŻSZĄ z fraz poniżej.
    var phrases = ['Bezpłatna diagnoza', 'Wyceń projekt', 'Umów rozmowę'];

    var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion:reduce)').matches;
    var i = 0;
    if(reduce){
      el.textContent = phrases[0];
      setInterval(function(){ i = (i + 1) % phrases.length; el.textContent = phrases[i]; }, 3200);
      return;
    }

    var ci = 0, deleting = false;
    function tick(){
      var full = phrases[i];
      if(!deleting){
        ci++;
        el.textContent = full.slice(0, ci);
        if(ci >= full.length){ deleting = true; return setTimeout(tick, 1800); }
        return setTimeout(tick, 60 + Math.random() * 45);
      }
      ci--;
      el.textContent = full.slice(0, ci);
      if(ci <= 0){ deleting = false; i = (i + 1) % phrases.length; return setTimeout(tick, 300); }
      return setTimeout(tick, 32);
    }
    el.textContent = '';
    setTimeout(tick, 800);
  })();
</script>

