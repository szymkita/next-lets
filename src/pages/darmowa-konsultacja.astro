<div class="s9-grid" style="position:relative;z-index:1;background:#0e2b1d;border-radius:26px;overflow:hidden;padding:0;display:grid;grid-template-columns:1fr 760px;gap:0;align-items:stretch;box-shadow:0 34px 84px -44px rgba(18,38,28,0.4);margin-top:clamp(40px,5vw,60px)">
