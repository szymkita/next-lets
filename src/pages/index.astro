---
// Strona Let's automate v9 — odtworzenie designu jako responsywna strona Astro
---
<!DOCTYPE html>
<html lang="pl">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Let's automate — Studio transformacji AI</title>
<link rel="icon" href="/uploads/logo-2.svg">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous">
<link href="https://fonts.googleapis.com/css2?family=Schibsted+Grotesk:ital,wght@0,400..900;1,400..900&display=swap" rel="stylesheet">
<style>
  :root{--la-accent:#00CD77}
  *{box-sizing:border-box}
  html{scroll-behavior:smooth}
  body{margin:0;background:#ffffff;overflow-x:clip;font-family:'Schibsted Grotesk',system-ui,sans-serif;-webkit-font-smoothing:antialiased}
  /* makieta hero: box 1180px skalowany transformem — poniżej 1240px przycinamy,
     żeby jego layoutowa szerokość nie powodowała poziomego przewijania */
  @media (max-width:1240px){ .mockup-frame{overflow:hidden} }
  a{color:inherit;text-decoration:none}
  ::selection{background:rgba(0,205,119,0.25)}
  input::placeholder,textarea::placeholder{color:#808b83}
  .inp{background:#f6f9f5 !important;border-color:#e4ebe2 !important;border-radius:11px !important;padding:14px 16px !important;transition:border-color .15s,background .15s,box-shadow .15s}
  .inp:focus{border-color:#0a7a52 !important;background:#ffffff !important;box-shadow:0 0 0 3px rgba(10,122,82,0.1)}
  .phone-field{transition:border-color .15s,box-shadow .15s,background .15s}
  .phone-field:focus-within{border-color:#0a7a52 !important;background:#ffffff !important;box-shadow:0 0 0 3px rgba(10,122,82,0.1)}
  @keyframes la-pulse{0%,100%{opacity:1}50%{opacity:.4}}
  @keyframes la-float{0%,100%{transform:translateY(-4px) rotate(var(--rot,0deg))}50%{transform:translateY(5px) rotate(var(--rot,0deg))}}

  .page{width:100%;margin:0 auto;background:#ffffff;color:#16211a}

  /* hover / focus */
  .nav-lnk{padding:7px 11px;border-radius:9px;transition:color .15s,background .15s}
  .nav-lnk:hover{color:#0a7a52 !important;background:rgba(10,122,82,0.07)}
  .btn-dark{transition:background .2s,color .2s}
  .btn-dark:hover{background:#0a7a52 !important;color:#fff !important}
  .btn-ghost{transition:color .15s,background .15s}
  .btn-ghost:hover{color:#0a7a52 !important;background:#fff !important}
  .btn-accent{transition:background .2s}
  .btn-accent:hover{background:#00b96c !important;color:#0b1a11 !important}
  .btn-cta{transition:background .2s,box-shadow .2s}
  .btn-cta:hover{background:#0c6a49 !important;box-shadow:0 14px 30px -14px rgba(10,122,82,0.6)}
  .lnk-green{transition:color .15s}
  .lnk-green:hover{color:#16211a !important}
  .lnk-accent{transition:color .15s}
  .lnk-accent:hover{color:#fff !important}
  .row-lnk{transition:color .15s}
  .row-lnk:hover{color:#0a7a52 !important}
  .foot-lnk{transition:color .15s}
  .foot-lnk:hover{color:#fff !important}
  .inp{transition:border-color .15s}
  .inp:focus{border-color:#0a7a52 !important}

  /* ---------- WARIANT A · DROGA POD HERO — reveal na scroll ---------- */
  .la-droga .dg-line{stroke-dasharray:1;stroke-dashoffset:1;transition:stroke-dashoffset 1.5s ease .1s}
  .la-droga.in .dg-line{stroke-dashoffset:0}
  .la-droga .dg-fill{opacity:0;transition:opacity 1.4s ease .1s}
  .la-droga.in .dg-fill{opacity:1}
  .la-droga .dg-dot{opacity:0;transform:scale(.3);transition:opacity .45s ease,transform .45s ease}
  .la-droga.in .dg-dot{opacity:1;transform:scale(1)}
  .la-droga .dg-conn{opacity:0;transition:opacity .5s ease}
  .la-droga.in .dg-conn{opacity:.9}
  .la-droga .dg-chip{opacity:0;transition:opacity .5s ease}
  .la-droga.in .dg-chip{opacity:1}
  .la-droga .dg-card{opacity:0;transform:translateY(14px);transition:opacity .5s ease,transform .5s cubic-bezier(0.4,0,0.2,1)}
  .la-droga.in .dg-card{opacity:1;transform:none}
  @media (prefers-reduced-motion:reduce){
    .la-droga .dg-line,.la-droga .dg-fill,.la-droga .dg-dot,.la-droga .dg-conn,.la-droga .dg-chip,.la-droga .dg-card{transition:none}
  }

  /* ---------- FAQ (akordeon) ---------- */
  .faq-item{border-top:1px solid #e7ece4}
  .faq-item:last-child{border-bottom:1px solid #e7ece4}
  .faq-q{appearance:none;width:100%;background:none;border:none;font-family:inherit;cursor:pointer;display:flex;align-items:center;justify-content:space-between;gap:20px;text-align:left;padding:24px 4px;font-size:clamp(17px,2vw,20px);font-weight:700;letter-spacing:-0.01em;color:#16211a;transition:color .15s}
  .faq-q:hover{color:#0a7a52}
  .faq-ico{flex-shrink:0;display:flex;align-items:center;justify-content:center;width:30px;height:30px;border-radius:50%;background:#e9f2ea;color:#0a7a52;transition:transform .35s cubic-bezier(0.4,0,0.2,1),background .2s}
  .faq-item.open .faq-ico{transform:rotate(180deg);background:var(--la-accent,#00CD77);color:#0b1a11}
  .faq-a{overflow:hidden;max-height:0;transition:max-height .4s cubic-bezier(0.4,0,0.2,1)}
  .faq-item.open .faq-a{max-height:340px}
  .faq-a-inner{padding:0 4px 26px;max-width:660px;font-size:15.5px;line-height:1.65;color:#4c5850;text-wrap:pretty}
  @media (prefers-reduced-motion:reduce){ .faq-a,.faq-ico{transition:none} }

  /* ---------- OPINIE (ściana / marquee) ---------- */
  .marq{position:relative;overflow:hidden;
    -webkit-mask:linear-gradient(90deg,transparent,#000 6%,#000 94%,transparent);
            mask:linear-gradient(90deg,transparent,#000 6%,#000 94%,transparent)}
  .marq-track{display:flex;gap:20px;width:max-content;will-change:transform;animation:marq-scroll 46s linear infinite}
  .marq:hover .marq-track{animation-play-state:paused}
  .marq-card{flex:0 0 auto;width:min(340px,80vw);display:flex;flex-direction:column;background:#ffffff;border:1px solid #e7ece4;border-radius:16px;padding:24px 24px 20px}
  @keyframes marq-scroll{from{transform:translateX(0)}to{transform:translateX(calc(-50% - 10px))}}
  @media (prefers-reduced-motion:reduce){
    .marq{overflow-x:auto;-webkit-mask:none;mask:none;scroll-snap-type:x mandatory}
    .marq-track{animation:none}
    .marq-card{scroll-snap-align:start}
    .marq-dup{display:none !important}
  }

  /* ---------- RESPONSYWNOŚĆ ---------- */
  @media (max-width:1024px){
    .faq-grid{grid-template-columns:1fr !important;gap:clamp(32px,5vw,48px) !important}
    .droga-cards{grid-template-columns:repeat(3,1fr) !important;gap:28px 22px !important}
    .s2-grid,.s6-grid,.s9-grid{grid-template-columns:1fr !important;gap:clamp(40px,6vw,64px) !important}
    .grid4{grid-template-columns:1fr 1fr !important}
  }
  @media (max-width:900px){
    .droga-cards{grid-template-columns:repeat(2,1fr) !important}
    .droga-cta{flex-direction:column !important;align-items:flex-start !important;gap:28px !important}
    .droga-cta-btns{align-items:stretch !important;width:100%}
    .droga-cta-btns a{justify-content:center !important;text-align:center}
    .s4-grid,.s8-grid,.metody-grid{grid-template-columns:1fr !important;gap:48px !important}
    .grid3{grid-template-columns:1fr !important;gap:32px !important}
    .foot-grid{grid-template-columns:1fr 1fr !important;gap:40px !important}
    .nav-menu{display:none !important}
    .s4-layers{position:static !important;height:auto !important;min-height:0 !important}
    .krok-layer{position:static !important;opacity:1 !important;transform:none !important;display:none !important}
    .krok-layer.active{display:block !important}
  }
  @media (max-width:600px){
    .droga-cards{grid-template-columns:1fr !important;gap:24px !important}
    .grid4,.grid2,.foot-grid{grid-template-columns:1fr !important}
    .hero-actions{flex-direction:column !important;align-items:stretch !important;width:100%}
    .hero-actions>div{width:100%}
    .hero-actions a{justify-content:center !important}
    .trust{flex-wrap:wrap !important;justify-content:center !important;text-align:center}
    .trust-logos{flex-wrap:wrap !important;justify-content:center !important;gap:22px !important}
    .stat-row{flex-wrap:wrap !important;gap:24px 32px !important}
    .metody-badge-row{flex-direction:column !important;align-items:flex-start !important;gap:16px !important}
    .final-badge-row{flex-wrap:wrap !important}
    .cta-card{grid-template-columns:1fr !important}
    .cta-portrait{display:none !important}
  }
  /* ---- sticky header + mega menu ---- */
  .site-header{position:sticky;top:0;z-index:60;padding:0 clamp(16px,4vw,40px);transition:padding-top .35s cubic-bezier(.4,0,.2,1)}
  .site-header.scrolled{padding-top:12px}
  .nav-pill{display:flex;align-items:center;justify-content:space-between;gap:20px;max-width:1440px;margin:0 auto;padding:16px 14px 16px 8px;background:transparent;border:1px solid transparent;border-radius:18px;box-shadow:none;transition:max-width .4s cubic-bezier(.4,0,.2,1),padding .35s cubic-bezier(.4,0,.2,1),background .3s,border-color .3s,box-shadow .3s}
  .site-header.scrolled .nav-pill{max-width:1180px;padding:8px 12px 8px 22px;background:rgba(255,255,255,0.78);backdrop-filter:blur(18px) saturate(1.5);-webkit-backdrop-filter:blur(18px) saturate(1.5);border-color:rgba(255,255,255,0.6);box-shadow:0 16px 46px -18px rgba(18,38,28,0.34)}
  .nav-item{display:flex;align-items:center}
  .mega-wrap{position:absolute;top:calc(100% - 20px);left:50%;transform:translateX(-50%) translateY(6px);width:min(940px,calc(100vw - 40px));padding-top:34px;opacity:0;visibility:hidden;pointer-events:none;transition:opacity .18s ease,transform .18s ease}
  .nav-item:hover .mega-wrap,.nav-item:focus-within .mega-wrap{opacity:1;visibility:visible;transform:translateX(-50%) translateY(0);pointer-events:auto}
  .nav-caret{transition:transform .2s}
  .nav-item:hover .nav-caret,.nav-item:focus-within .nav-caret{transform:rotate(180deg)}
  .mega-eyebrow{font-family:ui-monospace,Menlo,monospace;font-size:11px;letter-spacing:0.1em;text-transform:uppercase;color:#808b83;padding:0 11px;margin-bottom:6px}
  .mega-item{display:block;padding:9px 11px;border-radius:11px;transition:background .15s}
  .mega-item:hover{background:#f4f8f2}
  .mega-t{display:block;font-size:14.5px;font-weight:650;color:#16211a;transition:color .15s}
  .mega-item:hover .mega-t{color:#0a7a52}
  .mega-d{display:block;margin-top:2px;font-size:12.5px;line-height:1.4;color:#8b968d}
  .mega-feat{display:flex;flex-direction:column;justify-content:center;background:radial-gradient(120% 120% at 100% 0%, rgba(0,205,119,0.16), transparent 55%), #0e2b1d;border-radius:14px;padding:24px 22px;color:#ffffff;transition:transform .2s,box-shadow .2s}
  .mega-feat:hover{transform:translateY(-2px);box-shadow:0 22px 44px -22px rgba(0,0,0,0.5)}
  @media (max-width:900px){ .mega-wrap{display:none !important} }
  /* ---- Skala nagłówków ---- */
  .h-sec{font-size:clamp(30px,4.6vw,52px);line-height:1.05;letter-spacing:-0.028em;font-weight:800}
  .h-mod{font-size:clamp(24px,3.2vw,34px);line-height:1.1;letter-spacing:-0.02em;font-weight:800}
  .sub{font-size:17px;line-height:1.6;color:#4c5850;text-wrap:pretty}
  .sec-head{display:flex;align-items:flex-end;justify-content:space-between;flex-wrap:wrap;gap:24px 56px}
  /* ---- Dowody (S5) ---- */
  .proof-card{transition:transform .3s cubic-bezier(.4,0,.2,1),box-shadow .3s,border-color .3s}
  .proof-card:hover{transform:translateY(-4px);border-color:var(--la-accent,#00CD77);box-shadow:0 30px 60px -30px rgba(18,38,28,0.24)}
  @media (prefers-reduced-motion:reduce){ .proof-card{transition:none} .proof-card:hover{transform:none} }
  /* ---- Karty etapów (S3) + wiersze oferty ---- */
  .etap-card{transition:transform .3s cubic-bezier(.4,0,.2,1),box-shadow .3s,border-color .3s}
  .etap-card:hover{transform:translateY(-4px);border-color:var(--la-accent,#00CD77);box-shadow:0 26px 54px -32px rgba(18,38,28,0.22)}
  .row-lnk [aria-hidden="true"]{display:inline-block;transition:transform .18s}
  .row-lnk:hover [aria-hidden="true"]{transform:translateX(4px)}
  @media (prefers-reduced-motion:reduce){ .etap-card,.row-lnk [aria-hidden="true"]{transition:none} .etap-card:hover{transform:none} .row-lnk:hover [aria-hidden="true"]{transform:none} }
  .cta-contact{transition:color .15s}
  .cta-contact:hover{color:var(--la-accent,#00CD77) !important}
</style>
</head>
<body>

