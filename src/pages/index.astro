---
// Strona Let's automate v9 — odtworzenie designu jako responsywna strona Astro
---
<!DOCTYPE html>
<html lang="pl">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Let's automate — Studio transformacji AI</title>
<link rel="icon" href="/uploads/logo-2.svg">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous">
<link href="https://fonts.googleapis.com/css2?family=Schibsted+Grotesk:ital,wght@0,400..900;1,400..900&display=swap" rel="stylesheet">
<style>
  :root{--la-accent:#00CD77}
  *{box-sizing:border-box}
  html{scroll-behavior:smooth;overflow-x:hidden}
  body{margin:0;background:#ffffff;overflow-x:hidden;font-family:'Schibsted Grotesk',system-ui,sans-serif;-webkit-font-smoothing:antialiased}
  /* makieta hero: box 1180px skalowany transformem — poniżej 1240px przycinamy,
     żeby jego layoutowa szerokość nie powodowała poziomego przewijania */
  @media (max-width:1240px){ .mockup-frame{overflow:hidden} }
  a{color:inherit;text-decoration:none}
  ::selection{background:rgba(0,205,119,0.25)}
  input::placeholder{color:#9aa69c}
  @keyframes la-pulse{0%,100%{opacity:1}50%{opacity:.4}}
  @keyframes la-float{0%,100%{transform:translateY(-4px) rotate(var(--rot,0deg))}50%{transform:translateY(5px) rotate(var(--rot,0deg))}}

  .page{width:100%;margin:0 auto;background:#ffffff;color:#16211a}

  /* hover / focus */
  .nav-lnk{transition:color .15s}
  .nav-lnk:hover{color:#0a7a52 !important}
  .btn-dark{transition:background .2s,color .2s}
  .btn-dark:hover{background:#0a7a52 !important;color:#fff !important}
  .btn-ghost{transition:color .15s,background .15s}
  .btn-ghost:hover{color:#0a7a52 !important;background:#fff !important}
  .btn-accent{transition:background .2s}
  .btn-accent:hover{background:#00b96c !important;color:#0b1a11 !important}
  .lnk-green{transition:color .15s}
  .lnk-green:hover{color:#16211a !important}
  .lnk-accent{transition:color .15s}
  .lnk-accent:hover{color:#fff !important}
  .row-lnk{transition:color .15s}
  .row-lnk:hover{color:#0a7a52 !important}
  .foot-lnk{transition:color .15s}
  .foot-lnk:hover{color:#fff !important}
  .inp{transition:border-color .15s}
  .inp:focus{border-color:#0a7a52 !important}

  /* ---------- RESPONSYWNOŚĆ ---------- */
  @media (max-width:1024px){
    .s2-grid,.s6-grid,.s7-grid,.s9-grid{grid-template-columns:1fr !important;gap:clamp(40px,6vw,64px) !important}
    .grid4{grid-template-columns:1fr 1fr !important}
  }
  @media (max-width:900px){
    .s4-grid,.s8-grid,.metody-grid{grid-template-columns:1fr !important;gap:48px !important}
    .grid3{grid-template-columns:1fr !important;gap:32px !important}
    .foot-grid{grid-template-columns:1fr 1fr !important;gap:40px !important}
    .nav-menu{display:none !important}
    .s4-layers{position:static !important;height:auto !important;min-height:0 !important}
    .krok-layer{position:static !important;opacity:1 !important;transform:none !important;display:none !important}
    .krok-layer.active{display:block !important}
  }
  @media (max-width:600px){
    .grid4,.grid2,.foot-grid{grid-template-columns:1fr !important}
    .hero-actions{flex-direction:column !important;align-items:stretch !important;width:100%}
    .hero-actions>div{width:100%}
    .hero-actions a{justify-content:center !important}
    .trust{flex-wrap:wrap !important;justify-content:center !important;text-align:center}
    .trust-logos{flex-wrap:wrap !important;justify-content:center !important;gap:22px !important}
    .stat-row{flex-wrap:wrap !important;gap:24px 32px !important}
    .metody-badge-row{flex-direction:column !important;align-items:flex-start !important;gap:16px !important}
    .final-badge-row{flex-wrap:wrap !important}
  }
</style>
</head>
