<script>
  // ---- Hero: makieta pulpitu skalowana do szerokości kontenera ----
  (function(){
    var frame = document.querySelector('.mockup-frame');
    var scale = document.querySelector('.mockup-scale');
    if(!frame || !scale) return;
    function fit(){
      var w = frame.clientWidth;
      var s = Math.min(1, w / 1180);
      scale.style.transform = 'scale(' + s + ')';
      frame.style.height = (400 * s) + 'px';
    }
    fit();
    window.addEventListener('resize', fit);
    window.addEventListener('load', fit);
  })();

  // ---- Rotator (S1b) — pionowe przewijanie fraz co 3s ----
  (function(){
    var col = document.getElementById('rotator-col');
    if(!col) return;
    var count = col.children.length;
    var i = 0;
    setInterval(function(){
      i = (i + 1) % count;
      var h = col.children[0].offsetHeight || 60;
      col.style.transform = 'translateY(-' + (i * h) + 'px)';
    }, 3000);
  })();

  // ---- Zakładki oferty (S4) — Zaplanuj / Zbuduj / Wdróż ----
  (function(){
    var tabs = document.querySelectorAll('.krok-tab');
    var layers = document.querySelectorAll('.krok-layer');
    function setKrok(k){
      tabs.forEach(function(t){
        var on = t.dataset.krok === k;
        t.style.background = on ? '#ffffff' : 'transparent';
        t.style.boxShadow = on ? '0 12px 28px -16px rgba(12,28,20,0.3)' : 'none';
        var num = t.querySelector('.krok-num');
        if(num) num.style.color = on ? '#0a7a52' : '#9aa69c';
      });
      layers.forEach(function(l){
        var on = l.dataset.layer === k;
        l.style.opacity = on ? '1' : '0';
        l.style.transform = on ? 'translateY(0)' : 'translateY(14px)';
        l.style.pointerEvents = on ? 'auto' : 'none';
        l.classList.toggle('active', on);
      });
    }
    tabs.forEach(function(t){ t.addEventListener('click', function(){ setKrok(t.dataset.krok); }); });
    setKrok('plan');
  })();

  // ---- Rachunek (S2) — licznik od 0 do wartości docelowej gdy widoczny ----
  (function(){
    var el = document.getElementById('la8-rachunek');
    if(!el) return;
    var vals = el.querySelectorAll('.rcpt-val');
    var totalEl = document.getElementById('rcpt-total');
    var done = false;
    function animate(){
      if(done) return; done = true;
      var t0 = performance.now();
      function step(t){
        var p = Math.min(1, (t - t0) / 1500);
        var rp = 1 - Math.pow(1 - p, 3);
        vals.forEach(function(v){ v.textContent = Math.round(v.dataset.h * rp) + ' h'; });
        if(totalEl) totalEl.textContent = Math.round(totalEl.dataset.total * rp);
        if(p < 1) requestAnimationFrame(step);
      }
      requestAnimationFrame(step);
    }
    if('IntersectionObserver' in window){
      var io = new IntersectionObserver(function(entries){
        entries.forEach(function(e){ if(e.isIntersecting){ animate(); io.disconnect(); } });
      }, { threshold: 0.2 });
      io.observe(el);
    } else { animate(); }
  })();

  // ---- Pulpit (hero) — sporadyczny wzrost licznika zadań ----
  (function(){
    var numEl = document.getElementById('tasksNum');
    var labelEl = document.getElementById('tasksLabel');
    if(!numEl) return;
    var n = 42;
    function word(x){
      var m10 = x % 10, m100 = x % 100;
      return (m10 >= 2 && m10 <= 4 && !(m100 >= 12 && m100 <= 14)) ? 'zadania' : 'zadań';
    }
    setInterval(function(){
      if(Math.random() < 0.45){
        n += 1;
        numEl.textContent = n;
        if(labelEl) labelEl.textContent = n + ' ' + word(n) + ' zrobione dziś';
      }
    }, 5200);
  })();
</script>

